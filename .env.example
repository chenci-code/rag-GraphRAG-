# LLM keys
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
SILICONFLOW_API_KEY=

# Permission metadata store
GRAPHRAG_PERMISSION_MODE=mysql
GRAPHRAG_MYSQL_HOST=127.0.0.1
GRAPHRAG_MYSQL_PORT=3306
GRAPHRAG_MYSQL_USER=root
GRAPHRAG_MYSQL_DATABASE=graphrag
GRAPHRAG_MYSQL_PASSWORD=

# Optional Neo4j graph cleanup
GRAPHRAG_NEO4J_CLEANUP=false
GRAPHRAG_NEO4J_URI=
GRAPHRAG_NEO4J_USER=
GRAPHRAG_NEO4J_PASSWORD=

# OCR fallback for scanned PDFs
OCR_PROVIDER=deepseek
DEEPSEEK_OCR_MODEL=deepseek-ai/DeepSeek-OCR
DEEPSEEK_OCR_API_KEY=
GRAPHRAG_OCR_TIMEOUT_SECONDS=180
# GRAPHRAG_OCR_COMMAND=python scripts/deepseek_ocr.py "{input}"

# Server
GRAPHRAG_HOST=127.0.0.1
GRAPHRAG_PORT=8000
GRAPHRAG_CORS_ORIGINS=*
